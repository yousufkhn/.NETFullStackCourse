@{
    ViewData["Title"] = "Teacher Dashboard";
    var studentsPerDepartment = ViewBag.StudentsPerDepartment as IEnumerable<dynamic>;
}

<h2 class="mb-3">Teacher Dashboard</h2>

<div class="row mb-4">
    <div class="col-md-4 mb-2">
        <div class="card text-bg-primary">
            <div class="card-body">
                <h6>Total Departments</h6>
                <h3>@ViewBag.DepartmentCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-2">
        <div class="card text-bg-success">
            <div class="card-body">
                <h6>Total Courses</h6>
                <h3>@ViewBag.CourseCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-2">
        <div class="card text-bg-warning">
            <div class="card-body">
                <h6>Total Students</h6>
                <h3>@ViewBag.StudentCount</h3>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="list-group">
            <a asp-controller="Department" asp-action="Index" class="list-group-item list-group-item-action">Manage Departments</a>
            <a asp-controller="Course" asp-action="Index" class="list-group-item list-group-item-action">Manage Courses</a>
            <a asp-controller="Student" asp-action="Index" class="list-group-item list-group-item-action">Manage Students</a>
        </div>
    </div>
    <div class="col-md-6">
        <h5>Students Per Department</h5>
        <table class="table table-sm table-bordered">
            <thead>
                <tr><th>Department</th><th>Total Students</th></tr>
            </thead>
            <tbody>
                @if (studentsPerDepartment != null)
                {
                    @foreach (var item in studentsPerDepartment)
                    {
                        <tr>
                            <td>@item.DepartmentName</td>
                            <td>@item.StudentCount</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>