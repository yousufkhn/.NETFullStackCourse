@model IEnumerable<StudentManagementSystem.Models.Course>
@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Courses</h2>
    <a asp-action="Create" class="btn btn-primary">Add Course</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Course Name</th>
            <th>Duration</th>
            <th>Fees</th>
            <th>Department</th>
            <th width="180">Action</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CourseName</td>
            <td>@item.Duration</td>
            <td>@item.Fees.ToString("C")</td>
            <td>@item.Department?.DepartmentName</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.CourseId" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.CourseId" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>