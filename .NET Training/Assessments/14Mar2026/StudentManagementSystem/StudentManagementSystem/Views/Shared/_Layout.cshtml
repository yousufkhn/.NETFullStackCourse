<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Management System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StudentManagementSystem.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var role = Context.Session.GetString("Role");
        var fullName = Context.Session.GetString("FullName");
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Account" asp-action="Login">SMS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (role == "Teacher")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="TeacherDashboard" asp-action="Index">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Department" asp-action="Index">Departments</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Course" asp-action="Index">Courses</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Index">Students</a></li>
                        }
                        else if (role == "Student")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="StudentDashboard" asp-action="Index">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="StudentDashboard" asp-action="Profile">Profile</a></li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (!string.IsNullOrWhiteSpace(role))
                        {
                            <li class="nav-item"><span class="navbar-text me-3">@fullName (@role)</span></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Logout">Logout</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Register</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container pb-3">
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success">@successMessage</div>
        }
        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
