@model StudentManagementSystem.ViewModels.StudentProfileViewModel
@{
    ViewData["Title"] = "Student Dashboard";
}

<h2 class="mb-3">Student Dashboard</h2>

@if (string.IsNullOrEmpty(Model.StudentName))
{
    <div class="alert alert-warning">No profile data available.</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <h5 class="card-title">Welcome, @Model.StudentName</h5>
            <p class="mb-1"><strong>Email:</strong> @Model.Email</p>
            <p class="mb-1"><strong>Department:</strong> @Model.DepartmentName</p>
            <p class="mb-1"><strong>Course:</strong> @Model.CourseName</p>
            <p class="mb-3"><strong>Duration:</strong> @Model.CourseDuration | <strong>Fees:</strong> @Model.CourseFees.ToString("C")</p>
            <a asp-action="Profile" class="btn btn-primary">View / Update Profile</a>
        </div>
    </div>
}