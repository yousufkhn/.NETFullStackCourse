@model StudentManagementSystem.Models.Student
@{
    ViewData["Title"] = "Delete Student";
}

<h2>Delete Student</h2>
<div class="alert alert-warning">Are you sure you want to delete this student?</div>
<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.StudentName</dd>
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>
    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@Model.PhoneNumber</dd>
    <dt class="col-sm-3">Department</dt>
    <dd class="col-sm-9">@Model.Department?.DepartmentName</dd>
    <dt class="col-sm-3">Course</dt>
    <dd class="col-sm-9">@Model.Course?.CourseName</dd>
</dl>

<form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this record?');">
    <input type="hidden" asp-for="StudentId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>