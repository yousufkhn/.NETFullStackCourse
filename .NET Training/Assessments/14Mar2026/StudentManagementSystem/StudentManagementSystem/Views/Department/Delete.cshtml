@model StudentManagementSystem.Models.Department
@{
    ViewData["Title"] = "Delete Department";
}

<h2>Delete Department</h2>
<div class="alert alert-warning">Are you sure you want to delete this department?</div>
<dl class="row">
    <dt class="col-sm-3">Department</dt>
    <dd class="col-sm-9">@Model.DepartmentName</dd>
    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>
</dl>

<form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this record?');">
    <input type="hidden" asp-for="DepartmentId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>