@model StudentPortal.Models.Student

@{
    ViewData["Title"] = "Register Candidate";
}

<div class="d-flex justify-content-center">
    <div class="sp-form-card w-100">
        <!-- Header -->
        <div class="sp-form-icon-header" style="background:linear-gradient(135deg,#003875,#0070AD)">
            <i class="fas fa-user-plus"></i>
        </div>
        <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.2rem">
            <h2 style="font-size:1.5rem;font-weight:800;margin:0;color:#003875">Register Candidate</h2>
        </div>
        <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1.5rem">
            Capgemini .NET Training &middot; Batch March 2026
        </p>

        <hr class="sp-divider" />

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="sp-validation-summary"></div>

            <div class="sp-field">
                <label asp-for="FullName" class="sp-label"><i class="fas fa-user me-1"></i>Full Name</label>
                <input asp-for="FullName" class="sp-input" placeholder="e.g. Priya Sharma" />
                <span asp-validation-for="FullName" class="sp-validation"></span>
            </div>

            <div class="sp-field">
                <label asp-for="Email" class="sp-label"><i class="fas fa-envelope me-1"></i>Email Address</label>
                <input asp-for="Email" class="sp-input" placeholder="e.g. priya.sharma@capgemini.com" />
                <span asp-validation-for="Email" class="sp-validation"></span>
            </div>

            <div class="sp-field">
                <label asp-for="Phone" class="sp-label"><i class="fas fa-phone me-1"></i>Phone Number</label>
                <input asp-for="Phone" class="sp-input" placeholder="e.g. +91 98765 43210" />
                <span asp-validation-for="Phone" class="sp-validation"></span>
            </div>

            <div class="sp-field">
                <label asp-for="JoinDate" class="sp-label"><i class="fas fa-calendar me-1"></i>Join Date</label>
                <input asp-for="JoinDate" class="sp-input" type="date" />
                <span asp-validation-for="JoinDate" class="sp-validation"></span>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="sp-btn sp-btn-primary sp-btn-lg flex-grow-1">
                    <i class="fas fa-check"></i> Register Candidate
                </button>
                <a asp-action="Index" class="sp-btn sp-btn-secondary sp-btn-lg">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
