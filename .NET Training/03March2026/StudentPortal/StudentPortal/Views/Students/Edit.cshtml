@model StudentPortal.Models.Student

@{
    ViewData["Title"] = "Edit Candidate";
}

<div class="d-flex justify-content-center">
    <div class="sp-form-card w-100">
        <!-- Header -->
        <div class="sp-form-icon-header" style="background:linear-gradient(135deg,#0070AD,#12ABDB)">
            <i class="fas fa-user-pen"></i>
        </div>
        <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:0.2rem;color:#003875">Edit Candidate</h2>
        <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:1.5rem">
            Update candidate details &mdash; Capgemini .NET Training Batch 2026
        </p>

        <hr class="sp-divider" />

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="sp-validation-summary"></div>
            <input type="hidden" asp-for="StudentId" />

            <div class="sp-field">
                <label asp-for="FullName" class="sp-label"><i class="fas fa-user me-1"></i>Full Name</label>
                <input asp-for="FullName" class="sp-input" />
                <span asp-validation-for="FullName" class="sp-validation"></span>
            </div>

            <div class="sp-field">
                <label asp-for="Email" class="sp-label"><i class="fas fa-envelope me-1"></i>Email Address</label>
                <input asp-for="Email" class="sp-input" />
                <span asp-validation-for="Email" class="sp-validation"></span>
            </div>

            <div class="sp-field">
                <label asp-for="Phone" class="sp-label"><i class="fas fa-phone me-1"></i>Phone Number</label>
                <input asp-for="Phone" class="sp-input" />
                <span asp-validation-for="Phone" class="sp-validation"></span>
            </div>

            <div class="sp-field">
                <label asp-for="Status" class="sp-label"><i class="fas fa-circle-dot me-1"></i>Status</label>
                <select asp-for="Status" class="sp-input">
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
                <span asp-validation-for="Status" class="sp-validation"></span>
            </div>

            <div class="sp-field">
                <label asp-for="JoinDate" class="sp-label"><i class="fas fa-calendar me-1"></i>Join Date</label>
                <input asp-for="JoinDate" class="sp-input" type="date" />
                <span asp-validation-for="JoinDate" class="sp-validation"></span>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="sp-btn sp-btn-primary sp-btn-lg flex-grow-1" style="background:linear-gradient(135deg,#0070AD,#12ABDB);box-shadow:0 4px 14px rgba(0,112,173,0.40)">
                    <i class="fas fa-floppy-disk"></i> Save Changes
                </button>
                <a asp-action="Index" class="sp-btn sp-btn-secondary sp-btn-lg">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
